# ── Neon Postgres ────────────────────────────────────────────────
# Use the POOLED connection string from the Neon dashboard (ends with -pooler).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── Server ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (web build + admin panel).
CORS_ORIGINS="http://localhost:8081,http://localhost:3000"

# ── JWT ──────────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 48
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# ── Cloudinary (image & document storage) ───────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Razorpay ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ── Phone OTP (MSG91 for India; falls back to console in dev) ─────
MSG91_AUTH_KEY=""
MSG91_SENDER_ID="NXTGEN"
MSG91_OTP_TEMPLATE_ID=""
# Testing aid (esp. before DLT): whitelisted numbers skip MSG91 and accept the
# fixed OTP_TEST_CODE. Comma-separate multiple numbers. Leave empty in prod.
OTP_TEST_PHONES=""
OTP_TEST_CODE="123456"

# ── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="NxtGenProperties <no-reply@nxtgenproperties.com>"

# ── Google OAuth ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Expo Push ────────────────────────────────────────────────────
# Optional: Expo access token for higher push rate limits.
EXPO_ACCESS_TOKEN=""
