{
  "expo": {
    "name": "Nxt Gen Properties",
    "slug": "nxt-gen-properties",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nxtgenproperties.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35"
      },
      "package": "com.nxtgenproperties.app"
    },
    "web": {},
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to upload property images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "nxtgenproperties"
  }
}